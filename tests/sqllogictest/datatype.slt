statement ok
CREATE TABLE t (index serial primary key, embedding bm25vector);

statement ok
INSERT INTO t (embedding)
SELECT
    ARRAY(
        SELECT val
        FROM (
            SELECT
                ((('x' || substring(md5((64 * i + j)::text), 1, 16))::bit(64)::bigint % 128 + 128) % 128)::int AS val
            FROM generate_series(1, 64) d(j)
        ) sub
        ORDER BY val
    )
FROM generate_series(1, 2048) s(i);

# text format

query T
SELECT '{}'::bm25vector;
----
{}

query T
SELECT '{0:1}'::bm25vector;
----
{0:1}

query T
SELECT '{1:1,2:2}'::bm25vector;
----
{1:1, 2:2}

statement error incorrect vector
SELECT '{0:0}'::bm25vector;

statement error incorrect vector
SELECT '{333:1,222:2}'::bm25vector;

statement error failed to parse number
SELECT '{4294967296:1}'::bm25vector;

statement ok
COPY t TO '/tmp/t_format' WITH (FORMAT text);

statement ok
CREATE TABLE t_text (index serial primary key, embedding bm25vector);

statement ok
COPY t_text FROM '/tmp/t_format' WITH (FORMAT text);

query II
SELECT sum((t.embedding = t_text.embedding)::int), sum((t.embedding <> t_text.embedding)::int)
FROM t
FULL OUTER JOIN t_text USING (index)
WHERE t.index = t_text.index;
----
2048 0

statement ok
DROP TABLE t_text;

# binary format

statement ok
COPY t TO '/tmp/t_binary' WITH (FORMAT binary);

statement ok
CREATE TABLE t_binary (index serial primary key, embedding bm25vector);

statement ok
COPY t_binary FROM '/tmp/t_binary' WITH (FORMAT binary);

query II
SELECT sum((t.embedding = t_binary.embedding)::int), sum((t.embedding <> t_binary.embedding)::int)
FROM t
FULL OUTER JOIN t_binary USING (index)
WHERE t.index = t_binary.index;
----
2048 0

statement ok
DROP TABLE t_binary;

# cast

query T
SELECT '{1, 2, 1}'::int[]::bm25vector;
----
{1:2, 2:1}

query I
SELECT
    ARRAY[0,0,0,0,0,1,1,1,1,33,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,999]::bm25vector,
    ARRAY[55,55,55,55,55,1,55,55,55,55,55,55,55,55,55,0,1,55,55,55,1,999,55,1,55,55,0,33,0,0,0,55,55]::bm25vector,
    ARRAY[55,999,55,55,55,55,55,55,55,55,1,33,55,0,55,55,55,0,55,55,55,55,0,55,55,55,0,1,1,1,55,55,0]::bm25vector
;
----
{0:5, 1:4, 33:1, 55:22, 999:1} {0:5, 1:4, 33:1, 55:22, 999:1} {0:5, 1:4, 33:1, 55:22, 999:1}

query I
SELECT '{0:5, 1:4, 33:1, 55:22, 999:1}'::bm25vector::int[];
----
{0,0,0,0,0,1,1,1,1,33,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,55,999}

# operator

query B
SELECT '{}'::bm25vector = '{}'::bm25vector;
----
t

query B
SELECT '{1:1, 2:1}'::bm25vector = '{1:1, 2:1}'::bm25vector;
----
t

query B
SELECT '{1:1, 2:2}'::bm25vector = '{1:1, 2:2}'::bm25vector;
----
t

query B
SELECT '{1:1, 2:1}'::bm25vector = '{1:1, 2:2}'::bm25vector;
----
f

query B
SELECT '{1:1, 2:1, 3:1}'::bm25vector = '{1:1, 2:2}'::bm25vector;
----
f

query B
SELECT '{}'::bm25vector = '{1:1}'::bm25vector;
----
f

query B
SELECT '{1:1, 2:1}'::bm25vector <> '{1:1, 2:2}'::bm25vector;
----
t

query B
SELECT '{1:1, 2:1}'::bm25vector <> '{1:1, 2:1}'::bm25vector;
----
f

